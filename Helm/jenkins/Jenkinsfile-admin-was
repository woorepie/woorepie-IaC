pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
metadata:
  labels:
    app: jenkins-kaniko
spec:
  serviceAccountName: jenkins
  containers:
    - name: jnlp
      image: 572390531726.dkr.ecr.ap-northeast-2.amazonaws.com/woorepie/jenkins:agent-v1.0.2
      args: ['\$(JENKINS_SECRET)', '\$(JENKINS_NAME)']
      volumeMounts:
        - name: workspace-volume
          mountPath: /home/jenkins/agent
    - name: kaniko
      image: gcr.io/kaniko-project/executor:debug
      command: ['sleep']
      args: ['infinity']
      volumeMounts:
        - name: workspace-volume
          mountPath: /home/jenkins/agent
  volumes:
    - name: workspace-volume
      emptyDir: {}
"""
        }
    }

    environment {
        ECR_REPO = "572390531726.dkr.ecr.ap-northeast-2.amazonaws.com/woorepie/admin-was"
        INFRA_REPO = "https://github.com/woorepie/woorepie-IaC.git"
    }

    stages {
        stage('Checkout & Set Tag') {
            steps {
                container('jnlp') {
                    git url: 'https://github.com/woorepie/woorepie-admin.git',
                        branch: 'dev'
                    script {
                        env.IMAGE_TAG = sh(
                            script: "git rev-parse --short HEAD",
                            returnStdout: true
                        ).trim()
                        env.FULL_IMAGE = "${env.ECR_REPO}:${env.IMAGE_TAG}"
                        echo "Docker Image Tag: ${env.IMAGE_TAG}"
                    }
                }
            }
        }

        stage('Check gradlew Permission') {
            steps {
                container('jnlp') {
                    dir('wooreadmin') {
                        sh 'ls -l gradlew'
                    }
                }
            }
        }

        stage('Set gradlew Permission') {
            steps {
                container('jnlp') {
                    dir('wooreadmin') {
                        sh 'chmod +x gradlew'
                    }
                }
            }
        }

        stage('Build') {
            steps {
                container('jnlp') {
                    dir('wooreadmin') {
                        sh './gradlew clean build -x test'
                    }
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                container('kaniko') {
                    sh """
                        /kaniko/executor \\
                          --context=/home/jenkins/agent/workspace/${env.JOB_NAME} \\
                          --dockerfile=wooreadmin/Dockerfile \\
                          --destination=${env.FULL_IMAGE} \\
                          --cache=true \\
                          --verbosity=debug
                    """
                }
            }
        }

        stage('Update Helm Values') { // 변경사항 있을 때만 커밋/푸시
            steps {
                container('jnlp') {
                    withCredentials([usernamePassword(
                        credentialsId: 'github-token',
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_TOKEN'
                    )]) {
                        sh """
                            git clone ${INFRA_REPO}
                            cd woorepie-IaC
                            git checkout helm

                            # IMAGE_TAG를 따옴표로 감싸는 shell 변수 선언
                            IMAGE_TAG_WITH_QUOTE="\\\"${env.IMAGE_TAG}\\\""
                            sed -i "s|tag: .*|tag: \${IMAGE_TAG_WITH_QUOTE}|g" Helm/admin-was/values.yaml

                            git add Helm/admin-was/values.yaml

                            if ! git diff --cached --exit-code --quiet; then
                              git config user.name "Jenkins"
                              git config user.email "jenkins@woorepie.site"
                              git remote set-url origin https://$GIT_USER:$GIT_TOKEN@github.com/woorepie/woorepie-IaC.git
                              git commit -m "🔧edit: Update Admin-WAS image tag to ${env.IMAGE_TAG}"
                              git push origin helm
                            else
                              echo "No changes to commit."
                            fi
                        """
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
