pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
metadata:
  labels:
    app: jenkins-kaniko
spec:
  containers:
  - name: jnlp  # ✅ 커스텀 에이전트 (Dockerfile.agent 기반)
    image: 572390531726.dkr.ecr.ap-northeast-2.amazonaws.com/woorepie/jenkins:agent-v1.0.2
    args: ['\$(JENKINS_SECRET)', '\$(JENKINS_NAME)']
    volumeMounts:
      - name: workspace-volume
        mountPath: /home/jenkins/agent

  - name: kaniko  # ✅ Kaniko 컨테이너
    image: gcr.io/kaniko-project/executor:debug
    command: ['sleep']
    args: ['infinity']
    volumeMounts:
      - name: docker-config
        mountPath: /kaniko/.docker
      - name: workspace-volume
        mountPath: /home/jenkins/agent

  volumes:
  - name: docker-config
    secret:
      secretName: ecr-creds  # ECR 인증 시크릿
      items:
        - key: .dockerconfigjson
          path: config.json
  - name: workspace-volume
    emptyDir: {}
"""
        }
    }

    environment {
        ECR_REPO = "572390531726.dkr.ecr.ap-northeast-2.amazonaws.com/woorepie/was"
        INFRA_REPO = "https://github.com/woorepie/woorepie-IaC.git"
    }

    stages {
        stage('Checkout & Set Tag') {
            steps {
                container('jnlp') {
                    git url: 'https://github.com/woorepie/woorepie-spring.git',
                        branch: 'dev'
                    script {
                        // 환경변수에 할당해야 다음 stage에서도 사용됨!
                        env.IMAGE_TAG = sh(
                            script: "git rev-parse --short HEAD",
                            returnStdout: true
                        ).trim()
                        env.FULL_IMAGE = "${env.ECR_REPO}:${env.IMAGE_TAG}"
                        echo "Docker Image Tag: ${env.IMAGE_TAG}"
                    }
                }
            }
        }

        stage('Check gradlew Permission') {
            steps {
                container('jnlp') {
                    dir('woorepie') {
                        sh 'ls -l gradlew'
                    }
                }
            }
        }

        stage('Set gradlew Permission') {
            steps {
                container('jnlp') {
                    dir('woorepie') {
                        sh 'chmod +x gradlew'
                    }
                }
            }
        }

        stage('Build') {
            steps {
                container('jnlp') {
                    dir('woorepie') {
                        sh './gradlew clean build -x test'
                    }
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                container('kaniko') {
                    sh """
                        /kaniko/executor \\
                          --context=/home/jenkins/agent/workspace/${env.JOB_NAME} \\
                          --dockerfile=/home/jenkins/agent/workspace/${env.JOB_NAME}/woorepie/Dockerfile \\
                          --destination=${env.FULL_IMAGE} \\
                          --cache=true \\
                          --verbosity=debug
                    """
                }
            }
        }

        stage('Update Helm Values') {  // ✅ ArgoCD 연동 활성화
            steps {
                container('jnlp') {
                    withCredentials([usernamePassword(
                        credentialsId: 'github-token',
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_TOKEN'
                    )]) {
                        sh """
                            # IaC 레포지토리 클론
                            git clone ${INFRA_REPO}
                            cd woorepie-IaC
                            git checkout feat/helm/#10-helm

                            # values.yaml 업데이트
                            sed -i "s|tag: .*|tag: ${env.IMAGE_TAG}|g" Helm/was/values.yaml

                            # 변경사항 푸시
                            git config user.name "Jenkins"
                            git config user.email "jenkins@woorepie.site"
                            
                            # 인증 정보 포함된 remote로 변경
                            git remote set-url origin https://$GIT_USER:$GIT_TOKEN@github.com/woorepie/woorepie-IaC.git

                            git add Helm/was/values.yaml
                            git commit -m "🔧edit: Update WAS image tag to ${env.IMAGE_TAG}"
                            git push origin feat/helm/#10-helm
                        """
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
    }
}
